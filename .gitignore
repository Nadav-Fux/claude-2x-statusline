# ── Statusline runtime artifacts (written to ~/.claude/) ──
# These are created during normal statusline operation and should
# never be committed. They live in the user's home directory, but
# listing them here prevents accidental staging if running from source.
statusline-state.json
statusline-state.json.tmp
statusline-state.json.lock
statusline-usage-cache.json
statusline-schedule.json
statusline-config.json
statusline-context.json
.statusline-heartbeat
.statusline-telemetry-id
narrator-memory.json

# ── Review / audit docs (external, not for repo) ──
CODE_REVIEW_*.md

# ── Docs generated artifacts ──
docs/reports/
